{
  "version": 2,
  "builds": [
    {
      "src": "voice-order-ui/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "voice-order-ui/$1" }
  ],
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.9",
      "maxDuration": 10
    }
  },
  "env": {
    "PYTHONPATH": "."
  }
}
