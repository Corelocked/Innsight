{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "voice-order-ui/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "voice-order-ui/$1" }
  ],
  "installCommand": "cd voice-order-ui && npm ci",
  "buildCommand": "cd voice-order-ui && npm run build",
  "env": {
    "PYTHONPATH": "."
  }
}
